# App URL (used for SEO canonical URLs, sitemap, and API calls)
NEXT_PUBLIC_SITE_URL="http://localhost:3000/"

# MongoDB connection string (stores resume data: experience, projects, skills, etc.)
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/resume"

# GitHub username (fetches recent repos for the GitHub activity section)
GITHUB_USERNAME="your-github-username"

# Hashnode blog host (fetches published blog posts)
# Leave empty to disable blog integration
HASHNODE_HOST="your-username.hashnode.dev"

# SEO & branding
SITE_NAME="Your Site Name"
TWITTER_HANDLE="@your_handle"
LINKEDIN_URL="https://linkedin.com/in/your-username"

# Resume PDF filename (place the file in /public)
RESUME_PDF_PATH="/Your_Name_Resume.pdf"
